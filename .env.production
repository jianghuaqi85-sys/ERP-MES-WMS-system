# ===========================================
# 生产环境配置
# 复制此文件为 .env 并修改对应值
# ===========================================

# 数据库配置
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=erp_system

# Redis 配置
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# 应用密钥（必须修改！）
SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS

# CORS 配置（设置为实际前端域名）
CORS_ORIGINS=["https://your-domain.com"]
