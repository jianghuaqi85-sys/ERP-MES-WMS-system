# ===========================================
# ERP-MES-WMS 系统环境配置
# 复制此文件为 .env 并修改对应值
# ===========================================

# 应用配置
PROJECT_NAME="ERP-MES-WMS Traceability System"
ENVIRONMENT=development  # development / production

# 安全配置（生产环境必须修改！）
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 配置（生产环境设置为实际前端域名）
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# PostgreSQL 数据库配置
POSTGRES_SERVER=localhost
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=erp_system
POSTGRES_PORT=5434

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# RabbitMQ 配置（第四阶段启用）
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest
